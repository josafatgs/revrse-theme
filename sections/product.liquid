{{ 'product.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<div class="product-template" data-product-id="{{ product.id }}">
  <div class="product-container">
    
    <div class="product-hero">
      <div class="product-header">
        <div class="product-header-left">
          <h1 class="product-title">{{ product.title }}</h1>
          <div class="product-badges">
            <span class="badge badge-category">{{ product.category }}</span>
            {% if product.tags contains 'venta' %}<span class="badge badge-sale">Venta</span>{% endif %}
            {% if product.tags contains 'renta' %}<span class="badge badge-rent">Renta</span>{% endif %}
          </div>
        </div>

        <div class="product-header-right">
          <span class="product-price" id="variant-price">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          <a
            href="https://wa.me/2225138870?text=Quiero%20más%20información%20sobre%20la%20propiedad:%20{{ product.title | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-btn-product"
            id="whatsapp-link"
            data-base-url="https://wa.me/2225138870?text="
            data-product-title="{{ product.title | url_encode }}"
            data-product-url="{{ shop.url | append: product.url | url_encode }}"
          >
            {% render 'svg', icon: 'whatsapp' %}
            <span>Más información</span>
          </a>
        </div>
      </div>

      <div class="product-gallery-grid">
        {% render 'product-gallery', product: product %}
      </div>
    </div>

    <div class="property-info-section">
      <div style="display: flex; gap: 10px; flex-direction: column;">
          <div class="property-details">
          <h2>Detalles del Inmueble</h2>
          <div class="" id="">
            {% render 'product-specs', product: product %}
          </div>
        </div>

        <div class="property-details">
            <div class="brief-description">
              <h2>Descripción</h2>
              <div class="rte">
                {{ product.description }}
              </div>
            </div>
        </div>
      </div>

      <div class="property-contact">
        <h2>Solicitar información</h2>
        <div class="product-form">
          {% render 'product-form', product: product %}
        </div>
      </div>
    </div>

    {% if product.metafields.custom.youtube_video != blank %}
      <div class="property-video">
        <h2>Video de la propiedad</h2>
        <div class="video-container">
          {{ product.metafields.custom.youtube_video }}
        </div>
      </div>
    {% endif %}

  </div>
</div>

<style>
  /* --- VARIABLES Y BASES --- */
  :root {
    --spec-card-bg: #ffffff;
    --spec-card-border: #13CAE6;
    --block-bg: #ffffff;
    --block-border: #eeeeee;
    --bg-light: #f5f5f5;
  }

  .product-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 15px;
  }

  /* --- HEADER (Mobile First) --- */
  .product-header {
    display: flex;
    flex-direction: column; /* Apilado en móvil */
    gap: 20px;
    margin-bottom: 20px;
  }

  .product-title {
    font-size: 1.5rem;
    margin: 0 0 10px 0;
  }

  .product-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badge {
    padding: 6px 12px;
    border-radius: 20px;
    background: #46c4e0;
    font-size: 12px;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
  }

  .product-price {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: #111;
  }

  .whatsapp-btn-product {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: white;
    padding: 16px;
    border-radius: 10px;
    font-weight: 600;
    text-decoration: none;
    width: 100%; /* Full width en móvil */
  }

  /* --- INFO SECTION (Mobile First) --- */
  .property-info-section {
    display: flex;
    flex-direction: column; /* Una columna en móvil */
    gap: 20px;
    margin-top: 30px;
  }

  .property-details, .property-contact {
    background: var(--bg-light);
    padding: 20px;
    border-radius: 12px;
  }

  /* --- SPECS GRID --- */
  #variant-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* 2 columnas en móvil */
    gap: 10px;
    margin: 20px 0;
  }

  .spec-item {
    background: var(--spec-card-bg);
    border: 1.5px solid var(--spec-card-border);
    padding: 12px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    font-size: 13px;
  }

  /* --- VIDEO --- */
  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
  }
  .video-container iframe {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
  }

  /* --- DESKTOP QUERIES (Min-width 992px) --- */
  @media (min-width: 992px) {
    .product-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .product-title { font-size: 2.2rem; }

    .product-header-right { text-align: right; }
    
    .whatsapp-btn-product { width: auto; padding: 14px 28px; }

    .property-info-section {
      display: grid;
      grid-template-columns: 1.6fr 1fr; /* Proporción clásica real estate */
      gap: 30px;
    }

    #variant-specs {
      grid-template-columns: repeat(3, 1fr); /* 3 columnas en desktop */
    }

    .property-details, .property-contact { padding: 40px; }
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  // Clase VariantSelector optimizada
  class VariantSelector {
    constructor() {
      this.init();
    }

    init() {
      const variantButtons = document.querySelectorAll('.variant-option');
      variantButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          this.updateActiveUI(btn);
          this.updateContent(btn.dataset);
        });
      });
    }

    updateActiveUI(selectedBtn) {
      document.querySelectorAll('.variant-option').forEach(b => b.classList.remove('active'));
      selectedBtn.classList.add('active');
    }

    updateContent(data) {
      // Precio
      const priceEl = document.getElementById('variant-price');
      if (priceEl && data.variantPrice) priceEl.textContent = data.variantPrice;

      // Specs (Inyectar HTML limpio)
      const specsContainer = document.getElementById('variant-specs');
      if (specsContainer) {
        const specs = [
          { icon: '🛏️', label: 'Recámaras', value: data.variantBedrooms },
          { icon: '🚿', label: 'Baños', value: data.variantBathrooms },
          { icon: '🚗', label: 'Estacionamiento', value: data.variantParking },
          { icon: '📐', label: 'Área', value: data.variantArea ? `${data.variantArea} m²` : null },
          { icon: '🏠', label: 'Tipo', value: data.variantType }
        ];

        specsContainer.innerHTML = specs
          .filter(s => s.value && s.value != "0")
          .map(s => `
            <div class="spec-item">
              <span class="spec-icon">${s.icon}</span>
              <span class="spec-label">${s.label}</span>
              <span class="spec-value">${s.value}</span>
            </div>
          `).join('');
      }

      this.updateWhatsApp(selectedBtn.textContent.trim());
    }

    updateWhatsApp(variantName) {
      const link = document.getElementById('whatsapp-link');
      if (!link) return;
      const { baseUrl, productTitle, productUrl } = link.dataset;
      const message = `Hola, me interesa: ${decodeURIComponent(productTitle)} (Variante: ${variantName}) - ${decodeURIComponent(productUrl)}`;
      link.href = baseUrl + encodeURIComponent(message);
    }
  }

  document.addEventListener('DOMContentLoaded', () => new VariantSelector());
</script>