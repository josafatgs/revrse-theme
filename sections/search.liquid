{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

<h1>{{ 'search.title' | t }}</h1>

<form action="{{ routes.search_url }}" method="get" role="search">
  <input
    type="search"
    size="50"
    name="q"
    value="{{ search.terms | escape }}"
    placeholder="{{ 'search.placeholder' | t }}"
  >
  <button type="submit">{{ 'search.submit' | t }}</button>
</form>

{% if search.performed %}
  {% if search.results_count == 0 %}
    <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
  {% else %}
    <p>{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

    <div class="search-results">
      {% paginate search.results by 20 %}
       {% if search.results_count > 0 %}
            <div class="collection-products">
              {% for item in search.results %}
                {% if item.object_type == 'product' %}
                  
                  <script>
                    console.log("Entró al if: producto encontrado -> {{ item.title | escape }}");
                  </script>

                  {% render 'product', product: item %}
                {% endif %}
              {% endfor %}
            </div>

            {% comment %} Paginación {% endcomment %}
            <div class="collection-pagination">
                {{ paginate | default_pagination }}
            </div>

        {% else %}
            <p class="no-results-message">No se encontraron productos que coincidan con los filtros aplicados.</p>
        {% endif %}
       

        {{ paginate | default_pagination }}
      {% endpaginate %}
    </div>
  {% endif %}
{% endif %}

<style>
/* Grid container principal */
.collection-products {
  display: grid;
  gap: 16px; /* separación entre cards */
  
  /* Mobile First */
  grid-template-columns: repeat(1, 1fr); /* por defecto 1 columna en móvil */
}

/* Tablets */
@media screen and (min-width: 600px) {
  .collection-products {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Desktop */
@media screen and (min-width: 1024px) {
  .collection-products {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* Opcional: ajustar la altura de los cards para que sea uniforme */
.collection-products .pc-card {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* Paginación ocupa todo el ancho */
.collection-pagination {
  grid-column: 1 / -1;
  margin-top: 20px;
}

/* Ajustes generales de mobile inputs */
form[role="search"] {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

form[role="search"] input[type="search"] {
  flex: 1 1 auto;
  padding: 8px 12px;
  border: 1px solid #ccc;
  border-radius: 6px;
}

form[role="search"] button {
  padding: 8px 16px;
  border: none;
  background: #111;
  color: #fff;
  border-radius: 6px;
  cursor: pointer;
}

form[role="search"] button:hover {
  background: #000;
}
</style>

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
