{% comment %}
  Section: Video izquierda + info derecha (OS 2.0)
  - YouTube/Vimeo: setting type video_url (accept youtube/vimeo)
  - TikTok: pegar embed (blockquote + script)
  - Responsive: 2 columnas desktop, 1 columna móvil
{% endcomment %}

<section
  class="viw-{{ section.id }}"
  style="
    --viw-max: {{ section.settings.max_width }}px;
    --viw-pt: {{ section.settings.padding_top }}px;
    --viw-pb: {{ section.settings.padding_bottom }}px;
    --viw-gap: {{ section.settings.gap }}px;
    --viw-radius: {{ section.settings.radius }}px;
    --viw-bg: {{ section.settings.background }};
    --viw-text: {{ section.settings.text_color }};
    --viw-muted: {{ section.settings.muted_text_color }};
    --viw-btn-bg: {{ section.settings.button_bg }};
    --viw-btn-text: {{ section.settings.button_text }};
  "
>
  <div class="viw-container">
    <div class="viw-grid viw-align-{{ section.settings.vertical_align }}">
      <!-- VIDEO (IZQUIERDA) -->
      <div class="viw-video">
        {% if section.settings.video_source == 'youtube_vimeo' %}
          {% if section.settings.video_url != blank %}
            <div class="viw-video-frame viw-ratio-{{ section.settings.video_ratio | replace: '/', '-' | replace: ' ', '' }}">
              <iframe
                src="{{ section.settings.video_url }}"
                title="{{ section.settings.video_title | escape }}"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          {% else %}
            <div class="viw-video-placeholder">Agrega URL de YouTube/Vimeo en el editor</div>
          {% endif %}
        {% else %}
          {% if section.settings.tiktok_embed != blank %}
            <div class="viw-tiktok">
              {{ section.settings.tiktok_embed }}
            </div>
          {% else %}
            <div class="viw-video-placeholder">Pega el embed de TikTok en el editor</div>
          {% endif %}
        {% endif %}
      </div>

      <!-- INFO (DERECHA) -->
      <div class="viw-info">
        {% if section.settings.kicker != blank %}
          <div class="viw-kicker">{{ section.settings.kicker }}</div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="viw-title">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <div class="viw-text rte">
            {{ section.settings.text }}
          </div>
        {% endif %}

        {% if section.settings.features != blank %}
          {% assign feats = section.settings.features | newline_to_br | split: '<br />' %}
          <ul class="viw-features">
            {% for f in feats %}
              {% assign item = f | strip %}
              {% if item != blank %}
                <li>{{ item }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a class="viw-button" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .viw-{{ section.id }}{
    background: var(--viw-bg);
    padding: var(--viw-pt) 0 var(--viw-pb);
    color: var(--viw-text);
  }
  .viw-{{ section.id }} .viw-container{
    max-width: var(--viw-max);
    margin: 0 auto;
    padding: 0 16px;
  }

  /* VIDEO IZQUIERDA / INFO DERECHA */
  .viw-{{ section.id }} .viw-grid{
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--viw-gap);
  }

  .viw-{{ section.id }} .viw-align-top{ align-items: start; }
  .viw-{{ section.id }} .viw-align-center{ align-items: center; }
  .viw-{{ section.id }} .viw-align-bottom{ align-items: end; }

  /* YouTube/Vimeo */
  .viw-{{ section.id }} .viw-video-frame{
    width: 100%;
    border-radius: var(--viw-radius);
    overflow: hidden;
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .viw-{{ section.id }} .viw-video-frame iframe{
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .viw-{{ section.id }} .viw-ratio-16-9{ aspect-ratio: 16 / 9; }
  .viw-{{ section.id }} .viw-ratio-4-3{ aspect-ratio: 4 / 3; }
  .viw-{{ section.id }} .viw-ratio-1-1{ aspect-ratio: 1 / 1; }
  .viw-{{ section.id }} .viw-ratio-9-16{ aspect-ratio: 9 / 16; }

  /* TikTok */
  .viw-{{ section.id }} .viw-tiktok{
    border-radius: var(--viw-radius);
    overflow: hidden;
  }
  .viw-{{ section.id }} .viw-tiktok blockquote{
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .viw-{{ section.id }} .viw-video-placeholder{
    border-radius: var(--viw-radius);
    border: 1px dashed rgba(0,0,0,.25);
    padding: 18px;
    color: var(--viw-muted);
    background: rgba(0,0,0,.03);
  }

  .viw-{{ section.id }} .viw-kicker{
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--viw-muted);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .viw-{{ section.id }} .viw-title{
    margin: 0 0 10px;
    font-size: 34px;
    line-height: 1.1;
  }
  .viw-{{ section.id }} .viw-text{ opacity: .92; }
  .viw-{{ section.id }} .viw-features{
    margin: 14px 0 0;
    padding-left: 18px;
    opacity: .95;
  }
  .viw-{{ section.id }} .viw-features li{ margin: 6px 0; }

  .viw-{{ section.id }} .viw-button{
    display: inline-flex;
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: 10px;
    background: var(--viw-btn-bg);
    color: var(--viw-btn-text);
    text-decoration: none;
    font-weight: 800;
  }
  .viw-{{ section.id }} .viw-button:hover{ filter: brightness(.92); }

  /* Mobile */
  @media (max-width: 989px){
    .viw-{{ section.id }} .viw-grid{ grid-template-columns: 1fr; }
    .viw-{{ section.id }} .viw-title{ font-size: 26px; }
  }
</style>

{% schema %}
{
  "name": "Video (Izquierda) + Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "video_source",
      "label": "Fuente del video",
      "default": "youtube_vimeo",
      "options": [
        { "value": "youtube_vimeo", "label": "YouTube / Vimeo (URL)" },
        { "value": "tiktok", "label": "TikTok (Embed)" }
      ]
    },

    {
      "type": "video_url",
      "id": "video_url",
      "label": "URL del video (YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Título accesible del video",
      "default": "Video"
    },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Relación de aspecto (solo YouTube/Vimeo)",
      "default": "16 / 9",
      "options": [
        { "value": "16 / 9", "label": "16:9" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "9 / 16", "label": "9:16" }
      ]
    },

    {
      "type": "liquid",
      "id": "tiktok_embed",
      "label": "Embed de TikTok (pega el código 'Embed')",
      "info": "En TikTok: Share → Embed → copia y pega aquí"
    },

    { "type": "text", "id": "kicker", "label": "Texto superior (opcional)", "default": "Conócenos" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Tu título aquí" },
    { "type": "richtext", "id": "text", "label": "Texto", "default": "<p>Agrega aquí la descripción a la derecha del video.</p>" },
    { "type": "textarea", "id": "features", "label": "Lista (una por línea)", "default": "Envíos rápidos\nGarantía\nSoporte" },

    { "type": "text", "id": "button_label", "label": "Texto del botón", "default": "Ver más" },
    { "type": "url", "id": "button_link", "label": "Link del botón" },

    {
      "type": "select",
      "id": "vertical_align",
      "label": "Alineación vertical columnas",
      "default": "center",
      "options": [
        { "value": "top", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Abajo" }
      ]
    },

    { "type": "range", "id": "max_width", "min": 900, "max": 1600, "step": 50, "unit": "px", "label": "Ancho máximo", "default": 1200 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding inferior", "default": 48 },
    { "type": "range", "id": "gap", "min": 12, "max": 48, "step": 2, "unit": "px", "label": "Separación columnas", "default": 28 },
    { "type": "range", "id": "radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Radio contenedores", "default": 14 },

    { "type": "color", "id": "background", "label": "Fondo sección", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Texto principal", "default": "#111111" },
    { "type": "color", "id": "muted_text_color", "label": "Texto secundario", "default": "#666666" },

    { "type": "color", "id": "button_bg", "label": "Fondo botón", "default": "#111111" },
    { "type": "color", "id": "button_text", "label": "Texto botón", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Video (Izquierda) + Info" }
  ]
}
{% endschema %}
