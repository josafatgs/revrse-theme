{% comment %}
  Section: TikTok embeds (2 en desktop / 1 en móvil)
  - Usa blocks: puedes agregar 1 o 2 embeds
  - Desktop: 2 columnas si hay 2 blocks
  - Mobile: 1 columna y solo se muestra el primer embed
{% endcomment %}

<section class="ttg-{{ section.id }}">
  <div class="ttg-container">
    {% if section.settings.heading != blank %}
      <h2 class="ttg-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="ttg-grid">
      {% for block in section.blocks %}
        <div class="ttg-item" {{ block.shopify_attributes }}>
          {% if block.settings.embed_html != blank %}
            <div class="ttg-embed-wrap">
              <div class="ttg-embed-scale">
                {{ block.settings.embed_html }}
              </div>
            </div>
          {% else %}
            <div class="ttg-placeholder">Pega el embed oficial de TikTok en este bloque</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ttg-{{ section.id }}{
    background: {{ section.settings.section_bg }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    color: {{ section.settings.text_color }};
  }
  .ttg-{{ section.id }} .ttg-container{
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 16px;
  }
  .ttg-{{ section.id }} .ttg-heading{
    margin: 0 0 16px;
    font-size: 28px;
    line-height: 1.15;
  }

  /* Grid: 2 columnas en desktop, 1 en mobile */
  .ttg-{{ section.id }} .ttg-grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.gap }}px;
    align-items: start;
  }

  /* Wrapper del embed: sin fondo negro */
  .ttg-{{ section.id }} .ttg-embed-wrap{
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.radius }}px;
    background: transparent; /* quita el fondo negro */
    border: 1px solid {{ section.settings.border_color | color_modify: 'alpha', section.settings.border_opacity | times: 0.01 }};
  }

  /* TikTok suele traer min-width: 325px / max-width: 605px, lo escalamos en móvil */
  .ttg-{{ section.id }} .ttg-embed-scale{
    transform-origin: top left;
  }
  .ttg-{{ section.id }} .ttg-embed-scale blockquote,
  .ttg-{{ section.id }} .ttg-embed-scale blockquote.tiktok-embed{
    margin: 0 !important;
    min-width: 0 !important;
    max-width: 605px !important;
  }

  .ttg-{{ section.id }} .ttg-placeholder{
    border-radius: {{ section.settings.radius }}px;
    border: 1px dashed rgba(0,0,0,.25);
    padding: 14px;
    opacity: .75;
  }

  /* Mobile: 1 columna y oculta el 2do video */
  @media (max-width: 749px){
    .ttg-{{ section.id }} .ttg-grid{
      grid-template-columns: 1fr;
    }

    /* Solo mostrar el primer TikTok */
    .ttg-{{ section.id }} .ttg-item:nth-child(n+2){
      display: none;
    }

    /* Escalar el embed para que siempre quepa */
    .ttg-{{ section.id }} .ttg-embed-scale{
      transform: scale({{ section.settings.mobile_scale | divided_by: 100.0 }});
      width: calc(100% / ({{ section.settings.mobile_scale | divided_by: 100.0 }}));
    }
  }
</style>

{% schema %}
{
  "name": "TikTok 2 ",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título (opcional)", "default": "TikTok" },

    { "type": "range", "id": "max_width", "min": 700, "max": 1600, "step": 50, "unit": "px", "label": "Ancho máximo", "default": 1200 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding superior", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding inferior", "default": 40 },
    { "type": "range", "id": "gap", "min": 8, "max": 40, "step": 2, "unit": "px", "label": "Separación", "default": 18 },

    { "type": "range", "id": "radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Radio", "default": 14 },
    { "type": "color", "id": "border_color", "label": "Color borde", "default": "#000000" },
    { "type": "range", "id": "border_opacity", "min": 0, "max": 30, "step": 1, "unit": "%", "label": "Opacidad borde", "default": 10 },

    { "type": "color", "id": "section_bg", "label": "Fondo sección", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Color texto", "default": "#111111" },

    { "type": "range", "id": "mobile_scale", "min": 70, "max": 100, "step": 1, "unit": "%", "label": "Escala en móvil", "default": 80 }
  ],
  "blocks": [
    {
      "type": "tiktok",
      "name": "TikTok (Embed)",
      "limit": 2,
      "settings": [
        {
          "type": "html",
          "id": "embed_html",
          "label": "Embed HTML",
          "info": "Pega el código oficial de TikTok (blockquote + script embed.js)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TikTok 2 desktop / 1 móvil",
      "blocks": [
        { "type": "tiktok" },
        { "type": "tiktok" }
      ]
    }
  ]
}
{% endschema %}
