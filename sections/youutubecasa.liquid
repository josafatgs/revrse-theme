{% comment %}
  Section: Cuadro con video al centro y contenido alrededor
  - Centro: Video (YouTube/Vimeo por video_url o TikTok por embed)
  - Alrededor: top/left/right/bottom editables
  - Responsive: en móvil se apila (Top -> Video -> Bottom) y opcionalmente muestra left/right abajo
{% endcomment %}

<section
  class="vbox-{{ section.id }}"
  style="
    --vbox-max: {{ section.settings.max_width }}px;
    --vbox-pt: {{ section.settings.padding_top }}px;
    --vbox-pb: {{ section.settings.padding_bottom }}px;
    --vbox-bg: {{ section.settings.section_bg }};
    --vbox-card-bg: {{ section.settings.card_bg }};
    --vbox-text: {{ section.settings.text_color }};
    --vbox-muted: {{ section.settings.muted_text_color }};
    --vbox-border: {{ section.settings.border_color }};
    --vbox-border-a: {{ section.settings.border_opacity | times: 0.01 }};
    --vbox-radius: {{ section.settings.radius }}px;
    --vbox-gap: {{ section.settings.gap }}px;
    --vbox-pad: {{ section.settings.card_padding }}px;
    --vbox-btn-bg: {{ section.settings.button_bg }};
    --vbox-btn-text: {{ section.settings.button_text }};
  "
>
  <div class="vbox-container">
    <div class="vbox-card vbox-align-{{ section.settings.vertical_align }}">
      <!-- TOP -->
      <div class="vbox-top">
        {% if section.settings.top_kicker != blank %}
          <div class="vbox-kicker">{{ section.settings.top_kicker }}</div>
        {% endif %}
        {% if section.settings.top_heading != blank %}
          <h2 class="vbox-title">{{ section.settings.top_heading }}</h2>
        {% endif %}
        {% if section.settings.top_text != blank %}
          <div class="vbox-rte rte">{{ section.settings.top_text }}</div>
        {% endif %}
      </div>

      <!-- LEFT -->
      <div class="vbox-left">
        {% if section.settings.left_heading != blank %}
          <h3 class="vbox-subtitle">{{ section.settings.left_heading }}</h3>
        {% endif %}
        {% if section.settings.left_text != blank %}
          <div class="vbox-rte rte">{{ section.settings.left_text }}</div>
        {% endif %}

        {% if section.settings.left_list != blank %}
          {% assign items = section.settings.left_list | newline_to_br | split: '<br />' %}
          <ul class="vbox-list">
            {% for it in items %}
              {% assign t = it | strip %}
              {% if t != blank %}<li>{{ t }}</li>{% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <!-- VIDEO (CENTER) -->
      <div class="vbox-center">
        {% if section.settings.video_source == 'youtube_vimeo' %}
          {% if section.settings.video_url != blank %}
            <div class="vbox-video vbox-ratio-{{ section.settings.video_ratio | replace: '/', '-' | replace: ' ', '' }}">
              <iframe
                src="{{ section.settings.video_url }}"
                title="{{ section.settings.video_title | escape }}"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          {% else %}
            <div class="vbox-placeholder">Agrega URL de YouTube/Vimeo en el editor</div>
          {% endif %}
        {% else %}
          {% if section.settings.tiktok_embed != blank %}
            <div class="vbox-tiktok">
              {{ section.settings.tiktok_embed }}
            </div>
          {% else %}
            <div class="vbox-placeholder">Pega el embed de TikTok en el editor</div>
          {% endif %}
        {% endif %}
      </div>

      <!-- RIGHT -->
      <div class="vbox-right">
        {% if section.settings.right_heading != blank %}
          <h3 class="vbox-subtitle">{{ section.settings.right_heading }}</h3>
        {% endif %}
        {% if section.settings.right_text != blank %}
          <div class="vbox-rte rte">{{ section.settings.right_text }}</div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a class="vbox-button" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>

      <!-- BOTTOM -->
      <div class="vbox-bottom">
        {% if section.settings.bottom_text != blank %}
          <div class="vbox-bottom-text">{{ section.settings.bottom_text }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .vbox-{{ section.id }}{
    background: var(--vbox-bg);
    padding: var(--vbox-pt) 0 var(--vbox-pb);
    color: var(--vbox-text);
  }
  .vbox-{{ section.id }} .vbox-container{
    max-width: var(--vbox-max);
    margin: 0 auto;
    padding: 0 16px;
  }

  .vbox-{{ section.id }} .vbox-card{
    background: var(--vbox-card-bg);
    border: 1px solid color-mix(in srgb, var(--vbox-border) calc(var(--vbox-border-a) * 100%), transparent);
    border-radius: var(--vbox-radius);
    padding: var(--vbox-pad);
    display: grid;
    gap: var(--vbox-gap);
    grid-template-columns: 1fr minmax(320px, 1.2fr) 1fr;
    grid-template-rows: auto auto auto;
    grid-template-areas:
      "top top top"
      "left center right"
      "bottom bottom bottom";
    box-shadow: 0 10px 26px rgba(0,0,0,0.06);
  }

  .vbox-{{ section.id }} .vbox-align-top{ align-items: start; }
  .vbox-{{ section.id }} .vbox-align-center{ align-items: center; }
  .vbox-{{ section.id }} .vbox-align-bottom{ align-items: end; }

  .vbox-{{ section.id }} .vbox-top{ grid-area: top; text-align: center; }
  .vbox-{{ section.id }} .vbox-left{ grid-area: left; }
  .vbox-{{ section.id }} .vbox-center{ grid-area: center; }
  .vbox-{{ section.id }} .vbox-right{ grid-area: right; }
  .vbox-{{ section.id }} .vbox-bottom{ grid-area: bottom; text-align: center; }

  .vbox-{{ section.id }} .vbox-kicker{
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--vbox-muted);
    font-weight: 800;
    margin-bottom: 10px;
  }
  .vbox-{{ section.id }} .vbox-title{
    margin: 0 0 10px;
    font-size: 32px;
    line-height: 1.1;
  }
  .vbox-{{ section.id }} .vbox-subtitle{
    margin: 0 0 8px;
    font-size: 16px;
    line-height: 1.2;
  }
  .vbox-{{ section.id }} .vbox-rte{ opacity: .92; }
  .vbox-{{ section.id }} .vbox-list{
    margin: 10px 0 0;
    padding-left: 18px;
    opacity: .95;
  }
  .vbox-{{ section.id }} .vbox-list li{ margin: 6px 0; }

  /* Video */
  .vbox-{{ section.id }} .vbox-video{
    width: 100%;
    border-radius: calc(var(--vbox-radius) - 2px);
    overflow: hidden;
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .vbox-{{ section.id }} .vbox-video iframe{
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .vbox-{{ section.id }} .vbox-ratio-16-9{ aspect-ratio: 16 / 9; }
  .vbox-{{ section.id }} .vbox-ratio-4-3{ aspect-ratio: 4 / 3; }
  .vbox-{{ section.id }} .vbox-ratio-1-1{ aspect-ratio: 1 / 1; }
  .vbox-{{ section.id }} .vbox-ratio-9-16{ aspect-ratio: 9 / 16; }

  .vbox-{{ section.id }} .vbox-tiktok{
    border-radius: calc(var(--vbox-radius) - 2px);
    overflow: hidden;
  }
  .vbox-{{ section.id }} .vbox-tiktok blockquote{
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  .vbox-{{ section.id }} .vbox-placeholder{
    border-radius: calc(var(--vbox-radius) - 2px);
    border: 1px dashed rgba(0,0,0,.25);
    padding: 14px;
    color: var(--vbox-muted);
    background: rgba(0,0,0,0.03);
  }

  .vbox-{{ section.id }} .vbox-button{
    display: inline-flex;
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 10px;
    background: var(--vbox-btn-bg);
    color: var(--vbox-btn-text);
    text-decoration: none;
    font-weight: 800;
  }
  .vbox-{{ section.id }} .vbox-button:hover{ filter: brightness(.92); }

  .vbox-{{ section.id }} .vbox-bottom-text{
    margin-top: 6px;
    color: var(--vbox-muted);
    font-size: 13px;
  }

  /* Responsive */
  @media (max-width: 989px){
    .vbox-{{ section.id }} .vbox-card{
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto auto;
      grid-template-areas:
        "top"
        "center"
        "left"
        "right"
        "bottom";
    }
    .vbox-{{ section.id }} .vbox-title{ font-size: 24px; }
    .vbox-{{ section.id }} .vbox-top{ text-align: left; }
    .vbox-{{ section.id }} .vbox-bottom{ text-align: left; }
  }
</style>

{% schema %}
{
  "name": "Cuadro: Video",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "video_source",
      "label": "Fuente del video",
      "default": "youtube_vimeo",
      "options": [
        { "value": "youtube_vimeo", "label": "YouTube / Vimeo (URL)" },
        { "value": "tiktok", "label": "TikTok (Embed)" }
      ]
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "URL del video (YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"]
    },
    { "type": "text", "id": "video_title", "label": "Título accesible del video", "default": "Video" },
    {
      "type": "select",
      "id": "video_ratio",
      "label": "Relación de aspecto (solo YouTube/Vimeo)",
      "default": "16 / 9",
      "options": [
        { "value": "16 / 9", "label": "16:9" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "1 / 1", "label": "1:1" },
        { "value": "9 / 16", "label": "9:16" }
      ]
    },
    {
      "type": "liquid",
      "id": "tiktok_embed",
      "label": "Embed de TikTok",
      "info": "Pega el código de 'Embed' (incluye script embed.js)"
    },

    { "type": "text", "id": "top_kicker", "label": "Top: Kicker", "default": "Conócenos" },
    { "type": "text", "id": "top_heading", "label": "Top: Título", "default": "Tu título aquí" },
    { "type": "richtext", "id": "top_text", "label": "Top: Texto", "default": "<p>Descripción corta arriba del video.</p>" },

    { "type": "text", "id": "left_heading", "label": "Izquierda: Título", "default": "Detalles" },
    { "type": "richtext", "id": "left_text", "label": "Izquierda: Texto", "default": "<p>Información del lado izquierdo.</p>" },
    { "type": "textarea", "id": "left_list", "label": "Izquierda: Lista (una por línea)", "default": "Punto 1\nPunto 2\nPunto 3" },

    { "type": "text", "id": "right_heading", "label": "Derecha: Título", "default": "Más info" },
    { "type": "richtext", "id": "right_text", "label": "Derecha: Texto", "default": "<p>Información del lado derecho.</p>" },

    { "type": "text", "id": "button_label", "label": "Botón: Texto", "default": "Ver más" },
    { "type": "url", "id": "button_link", "label": "Botón: Link" },

    { "type": "text", "id": "bottom_text", "label": "Bottom: Texto inferior", "default": "Texto pequeño inferior (opcional)" },

    {
      "type": "select",
      "id": "vertical_align",
      "label": "Alineación vertical (desktop)",
      "default": "center",
      "options": [
        { "value": "top", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Abajo" }
      ]
    },

    { "type": "range", "id": "max_width", "min": 900, "max": 1600, "step": 50, "unit": "px", "label": "Ancho máximo", "default": 1200 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding superior", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding inferior", "default": 48 },

    { "type": "range", "id": "gap", "min": 10, "max": 40, "step": 2, "unit": "px", "label": "Separación interna", "default": 18 },
    { "type": "range", "id": "card_padding", "min": 12, "max": 48, "step": 2, "unit": "px", "label": "Padding del cuadro", "default": 22 },
    { "type": "range", "id": "radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Radio", "default": 14 },

    { "type": "color", "id": "section_bg", "label": "Fondo sección", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Fondo cuadro", "default": "#ffffff" },
    { "type": "color", "id": "border_color", "label": "Color borde", "default": "#000000" },
    { "type": "range", "id": "border_opacity", "min": 0, "max": 30, "step": 1, "unit": "%", "label": "Opacidad borde", "default": 10 },

    { "type": "color", "id": "text_color", "label": "Texto principal", "default": "#111111" },
    { "type": "color", "id": "muted_text_color", "label": "Texto secundario", "default": "#666666" },

    { "type": "color", "id": "button_bg", "label": "Fondo botón", "default": "#111111" },
    { "type": "color", "id": "button_text", "label": "Texto botón", "default": "#ffffff" }
  ],
  "presets": [
    { "name": "Cuadro: Video centro + Info" }
  ]
}
{% endschema %}
