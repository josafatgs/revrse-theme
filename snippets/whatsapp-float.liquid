{%- comment -%}
  WhatsApp floating button component
{%- endcomment -%}



{{ 'whatsapp-float.css' | asset_url | stylesheet_tag }}


<div class="whatsapp-float" role="complementary" aria-label="Contacto por WhatsApp">
<a id="whatsapp-link"
    href="https://wa.me/2225138870?text=Hola%2C+me+interesa+obtener+m%C3%A1s+informaci%C3%B3n" 
    target="_blank" 
    rel="noopener noreferrer"
    class="whatsapp-btn"
    aria-label="Contáctanos por WhatsApp"
    title="Enviar mensaje por WhatsApp"
    role="button">

    <!-- tu SVG se queda igual -->
</a>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const whatsappLink = document.getElementById("whatsapp-link");
    const phone = "2225138870";

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function(position) {

            const lat = position.coords.latitude;
            const lon = position.coords.longitude;

            const locationURL = `https://maps.google.com/?q=${lat},${lon}`;

            const message = encodeURIComponent(
                `Hola, me interesa obtener más información. 
Mi ubicación aproximada es: ${locationURL}`
            );

            whatsappLink.href = `https://wa.me/${phone}?text=${message}`;

        }, function() {

            const message = encodeURIComponent(
                "Hola, me interesa obtener más información."
            );

            whatsappLink.href = `https://wa.me/${phone}?text=${message}`;
        });
    }
});
</script>