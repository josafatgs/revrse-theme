{% assign has_specs = false %}

<table class="property-specs">
  <tbody>
    {% if product.metafields.custom.bedrooms != blank and product.metafields.custom.bedrooms != 0 %}
      {% assign has_specs = true %}
      <tr>
        <th>Recámaras</th>
        <td>{{ product.metafields.custom.bedrooms }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.bathrooms != blank and product.metafields.custom.bathrooms != 0 %}
      {% assign has_specs = true %}
      <tr>
        <th>Baños</th>
        <td>{{ product.metafields.custom.bathrooms }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.half_bathrooms != blank and product.metafields.custom.half_bathrooms != 0 %}
      {% assign has_specs = true %}
      <tr>
        <th>Medios Baños</th>
        <td>{{ product.metafields.custom.half_bathrooms }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.parking_spaces != blank and product.metafields.custom.parking_spaces != 0 %}
      {% assign has_specs = true %}
      <tr>
        <th>Estacionamiento</th>
        <td>{{ product.metafields.custom.parking_spaces }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.square_meters != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Área</th>
        <td>{{ product.metafields.custom.square_meters }} m²</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.lot_size != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Terreno</th>
        <td>{{ product.metafields.custom.lot_size }} m²</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.property_type != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Tipo</th>
        <td>{{ product.metafields.custom.property_type }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.year_built != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Año de construcción</th>
        <td>{{ product.metafields.custom.year_built }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.floors != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Pisos</th>
        <td>{{ product.metafields.custom.floors }}</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.garden == true %}
      {% assign has_specs = true %}
      <tr>
        <th>Jardín</th>
        <td>Sí</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.pool == true %}
      {% assign has_specs = true %}
      <tr>
        <th>Alberca</th>
        <td>Sí</td>
      </tr>
    {% endif %}

    {% if product.metafields.custom.furnished != blank %}
      {% assign has_specs = true %}
      <tr>
        <th>Amueblado</th>
        <td>
          {% if product.metafields.custom.furnished == true or product.metafields.custom.furnished == 'true' %}
            Sí
          {% else %}
            No
          {% endif %}
        </td>
      </tr>
    {% endif %}
  </tbody>
</table>

{% unless has_specs %}
  <p class="specs-empty">Especificaciones no disponibles</p>
{% endunless %}

<style>
    .property-specs{

  width:100%;
  border-collapse:collapse;
  margin:10px 0;
  font-size:15px;

  }

  .property-specs th{

  text-align:left;
  background:#34495e;
  color:white;
  padding:12px 14px;
  font-weight:600;
  width:40%;

  }

  .property-specs td{

  padding:12px 14px;
  border-bottom:1px solid #eee;

  }

  .property-specs tr:nth-child(even) td{
  background:#f7f9fb;
  }

  /* MOBILE */

  @media(max-width:768px){

  .property-specs th,
  .property-specs td{

  padding:10px;
  font-size:14px;

  }

  .property-specs th{
  width:100%;
  }

  }
</style>
