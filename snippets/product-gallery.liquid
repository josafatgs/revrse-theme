{% assign gallery_images = product.images %}

<div class="fibonacci-gallery" data-fibonacci-gallery>
  {% for image in gallery_images %}
    <div
      class="gallery-item item-{{ forloop.index }}"
      data-lightbox-trigger="{{ forloop.index0 }}"
    >
      <img
        src="{{ image | img_url: '900x' }}"
        srcset="
          {{ image | img_url: '400x' }} 400w,
          {{ image | img_url: '600x' }} 600w,
          {{ image | img_url: '900x' }} 900w,
          {{ image | img_url: '1200x' }} 1200w
        "
        sizes="(max-width:768px) 100vw, 33vw"
        alt="{{ image.alt | escape }}"
        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
      >
    </div>
  {% endfor %}
</div>

<!-- LIGHTBOX -->
<div class="gallery-lightbox" id="galleryLightbox">
  <span class="lightbox-close">&times;</span>

  <img class="lightbox-image" id="lightboxImage">

  <a class="lightbox-prev">❮</a>
  <a class="lightbox-next">❯</a>
</div>

<style>
    .fibonacci-gallery{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-bottom:30px;
}

/* items base mobile */

.gallery-item{
  position:relative;
  overflow:hidden;
  border-radius:8px;
  cursor:pointer;
  aspect-ratio:1/1;
}

.gallery-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .4s;
}

.gallery-item:hover img{
  transform:scale(1.05);
}

/* primera imagen grande en mobile */

.item-1{
  grid-column:1 / span 2;
}

/* DESKTOP */

@media (min-width:768px){

  .fibonacci-gallery{
    grid-template-columns:2fr 1fr 1fr;
    grid-template-rows:150px 150px 150px;
  }

  .gallery-item{
    aspect-ratio:auto;
  }

  .item-1{
    grid-row:1 / span 2;
    grid-column:1;
  }

  .item-2{
    grid-column:2;
    grid-row:1;
  }

  .item-3{
    grid-column:3;
    grid-row:1;
  }

  .item-4{
    grid-column:2;
    grid-row:2;
  }

  .item-5{
    grid-column:3;
    grid-row:2;
  }

}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('[data-lightbox-trigger]');
    const lightbox = document.getElementById('galleryLightbox');
    const lightboxImg = document.getElementById('lightboxImage');

    const prev = document.querySelector('.lightbox-prev');
    const next = document.querySelector('.lightbox-next');
    const close = document.querySelector('.lightbox-close');

    let currentIndex = 0;

    const gallery = [...images].map((el) => el.querySelector('img').src);

    function showImage(index) {
      currentIndex = index;

      lightboxImg.src = gallery[index];

      lightbox.classList.add('active');
    }

    images.forEach((img, i) => {
      img.addEventListener('click', () => {
        showImage(i);
      });
    });

    next.addEventListener('click', () => {
      currentIndex++;

      if (currentIndex >= gallery.length) {
        currentIndex = 0;
      }

      showImage(currentIndex);
    });

    prev.addEventListener('click', () => {
      currentIndex--;

      if (currentIndex < 0) {
        currentIndex = gallery.length - 1;
      }

      showImage(currentIndex);
    });

    close.addEventListener('click', () => {
      lightbox.classList.remove('active');
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        lightbox.classList.remove('active');
      }
    });
  });
</script>
