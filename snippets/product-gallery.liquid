{% assign gallery_images = product.images %}

<div class="fibonacci-gallery" data-fibonacci-gallery>
  {% for image in gallery_images %}
    <div 
      class="gallery-item item-{{ forloop.index }}" 
      data-lightbox-trigger="{{ forloop.index0 }}"
      data-full-src="{{ image | img_url: '1600x' }}"
    >
      <img
        src="{{ image | img_url: '600x' }}"
        srcset="{{ image | img_url: '400x' }} 400w, {{ image | img_url: '800x' }} 800w"
        sizes="(min-width: 769px) 33vw, 100vw"
        alt="{{ image.alt | escape }}"
        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
      >
    </div>
  {% endfor %}
</div>

<div class="gallery-lightbox" id="galleryLightbox" aria-hidden="true">
  <span class="lightbox-close">&times;</span>
  <img class="lightbox-image" id="lightboxImage" src="" alt="Zoom view">
  <button class="lightbox-nav lightbox-prev" aria-label="Anterior">❮</button>
  <button class="lightbox-nav lightbox-next" aria-label="Siguiente">❯</button>
</div>

<style>
  /* --- BASE / MOBILE FIRST --- */
  .fibonacci-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 2 columnas en móvil por defecto */
    {% comment %} gap: 10px; {% endcomment %}
    margin-bottom: 30px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 1 / 1; /* Mantiene cuadros perfectos en móvil */
  }

  /* La primera imagen destaca en móvil */
  .item-1 {
    grid-column: 1 / span 2;
    aspect-ratio: 16 / 9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  /* --- DESKTOP (Min-width 769px) --- */
  @media (min-width: 769px) {
    .fibonacci-gallery {
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: repeat(2, 200px); /* Altura fija para el efecto Fibonacci */
    }

    .gallery-item { aspect-ratio: auto; }

    .item-1 { grid-column: 1; grid-row: 1 / span 2; }
    .item-2 { grid-column: 2; grid-row: 1; }
    .item-3 { grid-column: 3; grid-row: 1; }
    .item-4 { grid-column: 2; grid-row: 2; }
    .item-5 { grid-column: 3; grid-row: 2; }

    .gallery-item:hover img { transform: scale(1.05); }
  }

  /* --- LIGHTBOX STYLES --- */
  .gallery-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.9);
    align-items: center;
    justify-content: center;
  }

  .gallery-lightbox.active { display: flex; }

  .lightbox-image {
    max-width: 90%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 4px;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 40px;
    color: #fff;
    cursor: pointer;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    padding: 20px;
    cursor: pointer;
  }

  .lightbox-prev { left: 10px; }
  .lightbox-next { right: 10px; }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const lightbox = document.getElementById('galleryLightbox');
  const lightboxImg = document.getElementById('lightboxImage');
  const items = document.querySelectorAll('[data-lightbox-trigger]');
  
  // Extraemos las URLs de alta resolución de los data-attributes
  const galleryUrls = [...items].map(el => el.dataset.fullSrc);
  let currentIndex = 0;

  const toggleLightbox = (state) => {
    lightbox.classList.toggle('active', state);
    lightbox.setAttribute('aria-hidden', !state);
    document.body.style.overflow = state ? 'hidden' : ''; // Evita scroll al estar abierto
  };

  const showImage = (index) => {
    currentIndex = (index + galleryUrls.length) % galleryUrls.length; // Lógica circular
    lightboxImg.src = galleryUrls[currentIndex];
  };

  items.forEach((item, index) => {
    item.addEventListener('click', () => {
      showImage(index);
      toggleLightbox(true);
    });
  });

  // Delegación de eventos para controles
  lightbox.addEventListener('click', (e) => {
    if (e.target.classList.contains('lightbox-next')) showImage(currentIndex + 1);
    if (e.target.classList.contains('lightbox-prev')) showImage(currentIndex - 1);
    if (e.target === lightbox || e.target.classList.contains('lightbox-close')) toggleLightbox(false);
  });

  // Soporte para teclado
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') toggleLightbox(false);
    if (e.key === 'ArrowRight') showImage(currentIndex + 1);
    if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
  });
});
</script>