{% liquid
  assign p = product
  assign sqm = p.metafields.custom.square_meters.value
  assign beds = p.metafields.custom.bedrooms.value
  assign baths = p.metafields.custom.bathrooms.value
%}

<article class="pc-card">
  <a class="pc-media" href="{{ p.url }}" aria-label="{{ p.title | escape }}">
    {% if p.featured_image %}
      <img
        src="{{ p.featured_image | image_url: width: 700 }}"
        alt="{{ p.featured_image.alt | default: p.title | escape }}"
        loading="lazy"
        width="700"
        height="700"
      >
    {% else %}
      <div class="pc-media-fallback"></div>
    {% endif %}

    {% if p.compare_at_price > p.price %}
      <span class="pc-badge">Oferta</span>
    {% endif %}

    <div class="pc-overlay">
    {% if sqm %}
      <div class="pc-meta">
        {{ sqm }} m²
      </div>
    {% endif %}

    {% if beds %}
      <div class="pc-meta">
        🛏 {{ beds }}
      </div>
    {% endif %}

    {% if baths %}
      <div class="pc-meta">
        🛁 {{ baths }}
      </div>
    {% endif %}
  </div>
  </a>

  <div class="pc-body">
    {% if p.vendor != blank %}
      <div class="pc-vendor">{{ p.vendor }}</div>
    {% endif %}

    <a class="pc-title" href="{{ p.url }}">
      {{ p.title }}
    </a>

    <div class="pc-price">
      <span class="pc-price-current">{{ p.price | money }}</span>

      {% if p.compare_at_price > p.price %}
        <span class="pc-price-compare">
          {{ p.compare_at_price | money }}
        </span>
      {% endif %}
    </div>
  </div>

  <a class="pc-cta" href="{{ p.url }}">
    Ver más
  </a>
</article>

<style>


    .pc-card{
  display:flex;
  flex-direction:column;
  height:100%;
  background:#fff;
  border:1px solid rgba(0,0,0,0.08);
  border-radius:12px;
  overflow:hidden;
  transition:box-shadow .2s ease;
}

.pc-card:hover{
  box-shadow:0 8px 24px rgba(0,0,0,0.08);
}

.pc-media{
  position:relative;
  display:block;
  aspect-ratio:1/1;
  background:#f5f5f5;
  overflow:hidden;
}

.pc-media img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform .25s ease;
}

.pc-card:hover .pc-media img{
  transform:scale(1.05);
}

.pc-badge{
  position:absolute;
  top:10px;
  left:10px;
  background:#e11d48;
  color:#fff;
  font-size:12px;
  font-weight:700;
  padding:6px 10px;
  border-radius:999px;
}

.pc-body{
  padding:14px;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.pc-vendor{
  font-size:12px;
  color:#777;
}

.pc-title{
  text-decoration:none;
  color:#111;
  font-weight:700;
  line-height:1.3;
}

.pc-title:hover{
  text-decoration:underline;
}

.pc-price{
  display:flex;
  gap:8px;
  align-items:center;
}

.pc-price-current{
  font-weight:700;
  color:#111;
}

.pc-price-compare{
  text-decoration:line-through;
  color:#888;
  font-size:13px;
}

.pc-cta{
  margin-top:auto;
  text-align:center;
  padding:12px;
  background:#F26800 ;
  color:#fff;
  text-decoration:none;
  font-weight:700;
}

.pc-cta:hover{
  background:#F26800 ;
}

.pc-overlay{
  position:absolute;
  bottom:0;
  left:0;
  width:100%;
  display:flex;
  justify-content:space-around;
  align-items:center;
  padding:8px 6px;
  background:rgba(0,0,0,0.45);
  color:#fff;
  font-weight:600;
  font-size:14px;
}

.pc-meta{
  display:flex;
  align-items:center;
  gap:4px;
}
</style>